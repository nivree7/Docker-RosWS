<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro"/>

    <!-- COLOR -->
    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- ROBOT BASE LINK-->
    <link name="base_link">
    
    </link>
    
    <joint name="base_link_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    
    <!-- ROBOT BASE FOOTPRINT -->
    <!--<joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>-->

    <link name="base_footprint">
    
    </link>

    <!-- ROBOT CHASSIS -->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="-0.45 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.45 0 0.1" />
            <geometry>
                <box size="0.9 0.4 0.2"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.45 0 0.1" />
            <geometry>
                <box size="0.9 0.4 0.2"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.9" y="0.4" z="0.2">
            <origin xyz="0.45 0 0.1" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/White</material>
    </gazebo>
    
    <!-- SENSOR POLE -->
    <joint name="pole_joint" type="fixed">
    	<parent link="chassis"/>
    	<child link="pole"/>
    	<origin xyz="0.45 0 0.4"/>
    </joint>
    
    <link name="pole">
    	<visual>
    	    <geometry>
    	    	<cylinder radius="0.03" length="0.6"/>
    	    </geometry>
    	    <material name="white"/>
    	</visual>
    	<collision>
	   <geometry>
    	    	<cylinder radius="0.03" length="0.6"/>
    	    </geometry>
    	</collision>
    	<xacro:inertial_cylinder mass="0.2" length="0.6" radius="0.03">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    
    <gazebo reference="pole">
        <material>Gazebo/White</material>
    </gazebo>

    <!-- LEFT WHEEL -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.4 0" rpy="-${pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.125" length="0.086"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.125" length="0.086"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.086" radius="0.125">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>

    <!-- RIGHT WHEEL -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.4 0" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.125" length="0.086"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.125" length="0.086"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.086" radius="0.125">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>

    <!-- CASTER WHEEL FRONT -->
    <joint name="caster_wheel_front_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel_front"/>
        <origin xyz="0.89 0 0"/>
    </joint>

    <link name="caster_wheel_front">
        <visual>
            <geometry>
                <sphere radius="0.125"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.125"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.125">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_front">
        <material>Gazebo/Black</material>
        <mu1>0.00001</mu1>
        <mu2>0.00001</mu2>
    </gazebo>

    <!-- CASTER WHEEL BACK -->

    <joint name="caster_wheel_back_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel_back"/>
        <origin xyz="0 0 0"/>
    </joint>

    <link name="caster_wheel_back">
        <visual>
            <geometry>
                <sphere radius="0.125"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.125"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.125">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>

    <gazebo reference="caster_wheel_back">
        <material>Gazebo/Black</material>
        <mu1>0.00001</mu1>
        <mu2>0.00001</mu2>
    </gazebo>
</robot>